// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Tabla de Usuarios
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String        // Aquí guardaremos la contraseña encriptada
  name         String
  avatarUrl    String?       // Aquí guardaremos la URL de la foto aleatoria
  daysTrained  Int           @default(0) // Contador de días entrenados
  role         String        @default("user")
  isActive     Boolean       @default(true)
  reservations Reservation[] // Relación: Un usuario tiene muchas reservas
  createdAt    DateTime      @default(now())
}

model Class {
  id           String        @id @default(uuid())
  date         DateTime
  capacity     Int
  reservations Reservation[]
}

model Reservation {
  id         String   @id @default(uuid())
  userId     String
  classId    String
  trainingId String   // <-- ¡NUEVO! El usuario elige su rutina
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  class      Class    @relation(fields: [classId], references: [id])
  training   Training @relation(fields: [trainingId], references: [id]) 
}

model Training {
  id           String        @id @default(uuid())
  name         String
  description  String?
  exercises    String[]      @default([])
  reservations Reservation[] 
}